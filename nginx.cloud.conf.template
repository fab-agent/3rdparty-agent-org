# nginx.cloud.conf.template — Alibaba Cloud ECS, wildcard subdomain
# Handles: agent.fab.engineering  AND  *.agent.fab.engineering
#
# Before using, replace:
#   ${DOMAIN}      → agent.fab.engineering
#   ${SSL_CERT}    → /etc/letsencrypt/live/fab.engineering/fullchain.pem
#   ${SSL_KEY}     → /etc/letsencrypt/live/fab.engineering/privkey.pem
#
# Wildcard SSL requires DNS challenge:
#   certbot certonly --manual --preferred-challenges dns \
#     -d agent.fab.engineering -d *.agent.fab.engineering
#
# Or use Alibaba Cloud SSL Certificate Service (free DV cert) for *.agent.fab.engineering

# Redirect HTTP → HTTPS
server {
    listen 80;
    server_name agent.fab.engineering *.agent.fab.engineering;
    return 301 https://$host$request_uri;
}

# Main HTTPS server — handles root + all subdomain tenants
server {
    listen 443 ssl http2;
    server_name agent.fab.engineering *.agent.fab.engineering;

    ssl_certificate     ${SSL_CERT};
    ssl_certificate_key ${SSL_KEY};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;

    # Rate limit on login
    location /auth/token {
        limit_req zone=login burst=5 nodelay;
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host            $host;
        proxy_set_header X-Real-IP       $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # Backend API
    location ~ ^/(auth|companies|departments|personnel|providers|sessions|flows|
                  task-requests|a2a|inbox|audit|backup|skills|policies|onboarding|
                  users|dashboard|database|git|social-media|journal|telegram|
                  system|tenant|docs|openapi\.json|redoc) {
        proxy_pass          http://127.0.0.1:8000;
        proxy_set_header    Host             $host;
        proxy_set_header    X-Real-IP        $remote_addr;
        proxy_set_header    X-Forwarded-For  $proxy_add_x_forwarded_for;
        proxy_read_timeout  300s;   # long timeout for SSE / streaming
        proxy_buffering     off;    # required for SSE
    }

    # SvelteKit frontend (catch-all)
    location / {
        proxy_pass       http://127.0.0.1:5173;
        proxy_set_header Host            $host;
        proxy_set_header X-Real-IP       $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 60s;
    }

    # Logs
    access_log /var/log/nginx/agent-fab-access.log;
    error_log  /var/log/nginx/agent-fab-error.log;
}

# Rate limit zone (put in http{} block of nginx.conf if not already there)
# limit_req_zone $binary_remote_addr zone=login:10m rate=5r/m;
