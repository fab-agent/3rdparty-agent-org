# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a strong random string before running in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-before-going-to-production

# ── Email (optional) ───────────────────────────────────────────────────────────
# Resend API key for sending invite and password reset emails.
# Without this, invite tokens are printed to the console log instead.
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
APP_URL=http://localhost:5173

# ── First-run admin account ────────────────────────────────────────────────────
# These credentials are used once on first startup to seed the founder account.
# Change FOUNDER_PASSWORD to something strong. You can rotate it after first login.
FOUNDER_EMAIL=admin@yourdomain.com
FOUNDER_PASSWORD=change-me-on-first-login
